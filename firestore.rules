rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction utilitaire pour récupérer le profil de l'utilisateur connecté
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Écoles -- annuaire public du marketplace. Un visiteur anonyme qui
    // consulte /schools/:id (SchoolDetail.jsx, SchoolEnrollment.jsx) doit
    // pouvoir lire le profil public d'une école SANS être connecté --
    // c'est le bug corrigé ici : l'ancienne règle exigeait request.auth
    // != null même pour une simple lecture publique.
    match /schools/{schoolId} {
      allow read: if true;

      // La création est autorisée lors de l'inscription -- mais les
      // memes champs d'abonnement interdits en update() ci-dessous
      // doivent l'etre ici aussi : sans cette restriction, n'importe
      // quel utilisateur connecte pouvait creer sa propre ecole avec
      // subscriptionActive: true des la creation, contournant
      // entierement le webhook FedaPay signe (meme classe de faille
      // que celle deja corrigee sur update()). activationCode est
      // desormais aussi interdit ici : ce champ vivait avant sur ce
      // document PUBLIC (allow read: if true ci-dessus), alors que
      // c'est le credential meme qui autorise reecrire le backendUrl
      // d'une ecole - n'importe qui pouvait le lire et detourner
      // n'importe quelle ecole. Il vit maintenant sous
      // schools/{id}/secrets/config (regle plus bas, deja reservee au
      // fondateur) - RegisterPage.jsx l'y ecrit juste apres avoir cree
      // ce document et le document users/{uid} du fondateur.
      allow create: if isSignedIn()
                    && !request.resource.data.keys().hasAny(
                          ['subscriptionActive', 'subscriptionExpiresAt', 'subscriptionStatus',
                           'activationCode', 'lastPaymentDate', 'lastPaymentTx']);

      // SEUL le fondateur lié à cette école a le droit de modifier les infos (comme le backendUrl) --
      // MAIS jamais les champs d'abonnement. Ces champs ne sont écrits que par
      // le webhook FedaPay signé (ardoise-api, via le SDK Admin qui ignore ces
      // règles) après confirmation réelle du paiement -- un fondateur qui
      // appelait updateDoc() directement depuis le client (SubscriptionPanel.jsx,
      // corrigé) pouvait sinon s'auto-activer un abonnement gratuit sans jamais
      // payer, puisque cette règle ne restreignait aucun champ.
      allow update: if isSignedIn()
                    && getUserData().role == 'founder'
                    && getUserData().schoolId == schoolId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['subscriptionActive', 'subscriptionExpiresAt', 'subscriptionStatus',
                                   'activationCode', 'lastPaymentDate', 'lastPaymentTx']);
      allow delete: if isSignedIn()
                    && getUserData().role == 'founder'
                    && getUserData().schoolId == schoolId;

      // Règles pour les secrets (clés FedaPay, WhatsApp...) : strictement réservé au fondateur de l'école
      match /secrets/{secretDoc} {
        allow read, write: if isSignedIn()
                           && getUserData().role == 'founder'
                           && getUserData().schoolId == schoolId;
      }
    }

    // Utilisateurs
    match /users/{userId} {
      // TeacherList.jsx/TeacherDetail.jsx sont l'annuaire PUBLIC de
      // tuteurs du marketplace (meme logique que schools/jobs
      // ci-dessus - visitable sans compte) et interrogent cette
      // collection avec where('role','==','teacher'). Une requete par
      // collection doit satisfaire la regle sur CHAQUE document
      // potentiellement concerne - `isSignedIn()` seul refusait donc
      // silencieusement tout visiteur anonyme (aucun teacher n'a
      // jamais pu s'afficher pour un visiteur non connecte), sans
      // jamais remonter d'erreur cote client (onSnapshot avale
      // l'erreur dans son callback d'echec). Le profil PARENT/staff/
      // fondateur reste prive - seul role == 'teacher' est ouvert en
      // lecture publique.
      // Le commentaire ci-dessus disait deja l'intention (profil prive
      // sauf teacher) mais isSignedIn() etait OR'd independamment du role
      // -- n'importe quel compte connecte pouvait donc lire le profil
      // (email/telephone/role/schoolId) de N'IMPORTE QUEL autre
      // utilisateur en connaissant son uid, pas seulement les tuteurs
      // publics. Trouve en revue de securite live.
      // ParentPortal.jsx interroge cette collection avec
      // where('parentId','==', parentId).where('role','==','marketplace_student')
      // pour lister les comptes enfants (createChildProfile, Cloud
      // Function - creation via Admin SDK, donc deja hors de portee de
      // la regle allow create ci-dessous). Sans cette clause, le
      // parent ne pouvait jamais RELIRE les profils qu'il venait de
      // creer server-side - onSnapshot echouait en permission-denied
      // en boucle, le compte enfant restait invisible indefiniment
      // malgre une creation reussie.
      allow read: if (isSignedIn() && request.auth.uid == userId)
                  || resource.data.role == 'teacher'
                  || (isSignedIn() && resource.data.role == 'marketplace_student' && resource.data.parentId == request.auth.uid);

      // La création (inscription - RegisterPage.jsx) est le tout premier
      // write sur ce document : resource n'existe pas encore, donc
      // resource.data plante dans une seule règle allow write commune à
      // create et update - Firestore traite une règle qui plante comme
      // un refus. C'est ce qui cassait TOUTE inscription (role/schoolId
      // sont justement les champs que RegisterPage.jsx doit écrire au
      // tout premier write). Séparée de update, qui garde la vraie
      // restriction de sécurité : après création, role/schoolId/
      // subscriptionActive ne doivent plus jamais changer côté client.
      //
      // MAIS la restriction sur update() ne protege que le DEUXIEME
      // write - le tout premier (create) n'avait aucune contrainte sur
      // les VALEURS de role/schoolId. N'importe quel compte pouvait donc
      // s'auto-attribuer role:'superadmin' ou schoolId d'une ecole
      // existante des la creation, et chaque autre regle de ce fichier
      // fait confiance a getUserData() (qui lit ce document) - escalade
      // de privileges complete (secrets FedaPay/WhatsApp de n'importe
      // quelle ecole, tickets support toutes ecoles confondues, etc).
      // Trouve en revue de securite live. RegisterPage.jsx ne definit
      // schoolId QUE pour role=='founder' (juste apres avoir cree le
      // document schools/{id} correspondant) - jamais pour
      // parent/teacher/developer.
      allow create: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role in ['parent', 'teacher', 'founder', 'developer']
                    && (request.resource.data.role == 'founder'
                          ? ('schoolId' in request.resource.data
                              && exists(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)))
                          : !('schoolId' in request.resource.data));
      allow update: if isSignedIn()
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role', 'schoolId', 'subscriptionActive']);
    }

    // Offres d'emploi -- tableau public du marketplace, lecture libre.
    // Seul le fondateur de l'école concernée peut créer/modifier/supprimer
    // une offre pour SA propre école.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && getUserData().role == 'founder'
                    && getUserData().schoolId == request.resource.data.schoolId;
      allow update, delete: if isSignedIn()
                            && getUserData().role == 'founder'
                            && getUserData().schoolId == resource.data.schoolId;
    }

    // Candidatures -- un professeur crée la sienne (JobApplicationFlow.jsx) ;
    // seuls le candidat lui-même et le fondateur de l'école concernée
    // peuvent la lire/la mettre à jour (FounderDashboard.jsx).
    match /job_applications/{applicationId} {
      allow create: if isSignedIn()
                    && getUserData().role == 'teacher'
                    && request.resource.data.teacherId == request.auth.uid;
      allow read, update: if isSignedIn() && (
        request.auth.uid == resource.data.teacherId ||
        (getUserData().role == 'founder' && getUserData().schoolId == resource.data.schoolId)
      );
    }

    // Demandes d'inscription -- un parent crée la sienne, encore non
    // examinee (status: 'pending_review', SchoolEnrollment.jsx). L'école
    // accepte/refuse via le pont signe (apps/core/api_views.py's
    // MarketplaceEnrollmentStatusUpdateView -> ardoise-api's PATCH
    // .../status route, Admin SDK - ces ecritures serveur ignorent ces
    // regles, elles ne s'appliquent qu'au SDK client). Le passage a
    // paymentStatus: 'paid_on_ardoise' est reserve au webhook FedaPay
    // signe (ardoise-api) -- avant ce fix, le client lui-meme (onComplete
    // du bouton de paiement) ecrivait directement ce changement de
    // statut, donc une ecole pouvait voir/traiter une demande jamais
    // reellement payee, et un parent aurait pu forcer "paye" depuis les
    // devtools sans payer. Ni le parent ni le fondateur n'ont plus besoin
    // d'ecrire directement sur ce document cote client - EnrollmentPanel.jsx
    // et la prise de rendez-vous passent toutes deux par ces routes
    // signees maintenant, donc `allow update` ci-dessous ne sert plus
    // qu'a bloquer une ecriture client qui tenterait de contourner ce pont.
    match /school_enrollment_requests/{requestId} {
      allow create: if isSignedIn()
                    && getUserData().role == 'parent'
                    && request.resource.data.parentId == request.auth.uid
                    && request.resource.data.status == 'pending_review';
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.parentId ||
        ((getUserData().role == 'founder' || getUserData().role == 'secretary') && getUserData().schoolId == resource.data.schoolId)
      );
      allow update: if false;
    }

    // Contrats de tutorat -- crees UNIQUEMENT par le webhook FedaPay
    // signe (ardoise-api) apres confirmation reelle du paiement, jamais
    // par le client (TutoringBookingFlow.jsx faisait avant un addDoc()
    // direct sur son propre onComplete, non verifie serveur). Seuls le
    // parent et le tuteur concerne peuvent le lire (ParentPortal "Mes
    // Cours de Soutien", TeacherMarketplaceDashboard "Mes Contrats").
    // Cette collection n'avait AUCUNE regle du tout avant ce fix --
    // Firestore refuse par defaut tout chemin non couvert, donc chaque
    // lecture/ecriture echouait silencieusement (aucun gestionnaire
    // d'erreur sur les onSnapshot) : un parent payait reellement via
    // FedaPay mais le contrat n'atteignait jamais Firestore, et
    // personne ne pouvait le voir meme quand l'ecriture passait par le
    // client (rare, car elle aussi refusee).
    match /tutoring_contracts/{contractId} {
      allow create, update: if false;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.parentId ||
        request.auth.uid == resource.data.teacherId
      );
    }

    // Montants dus a l'ecole par Ardoise (frais d'inscription collectes
    // pour le compte de l'ecole -- voir le webhook FedaPay : Ardoise
    // encaisse via sa propre cle FedaPay, l'ecole redemande ensuite ces
    // montants). Ecrit uniquement par le webhook signe (Admin SDK,
    // ignore ces regles) ; seul le fondateur de l'ecole concernee peut
    // consulter ce qui lui est du.
    match /school_payouts_owed/{payoutId} {
      allow read: if isSignedIn()
                  && getUserData().role == 'founder'
                  && getUserData().schoolId == resource.data.schoolId;
      allow create, update, delete: if false;
    }

    // Tickets de support -- n'importe qui (y compris un visiteur anonyme)
    // peut créer un ticket via le formulaire de contact public
    // (ContactForm.jsx) ; les agents de la plateforme peuvent les lire
    // et les mettre à jour.
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read, update: if isSignedIn() && getUserData().role in ['superadmin', 'support_agent', 'school_onboarding', 'dev_onboarding', 'billing_agent', 'marketing_agent'];
    }

    // Transactions FedaPay -- écrites uniquement par le Worker
    // ardoise-api via le SDK Admin (qui ignore ces règles), jamais par
    // un client. Aucun accès client, ni lecture ni écriture.
    match /transactions/{transactionId} {
      allow read, write: if false;
    }

    // Programme Développeur : Clés API
    match /api_keys/{keyId} {
      allow create: if isSignedIn() 
                    && getUserData().role == 'developer'
                    && request.resource.data.developerId == request.auth.uid;
      allow read, update, delete: if isSignedIn() 
                    && resource.data.developerId == request.auth.uid;
    }

    // Programme Développeur : Webhooks
    match /webhooks/{webhookId} {
      allow create: if isSignedIn() 
                    && getUserData().role == 'developer'
                    && request.resource.data.developerId == request.auth.uid;
      allow read, update, delete: if isSignedIn() 
                    && resource.data.developerId == request.auth.uid;
    }

    // Programme Développeur : Paramètres (Payout, etc)
    match /developer_settings/{settingId} {
      allow create, read, update: if isSignedIn() 
                    && getUserData().role == 'developer'
                    && request.auth.uid == settingId;
    }

    // Collection historique, remplacée par users/{uid}.role +
    // POST /api/team/invite (voir SuperadminDashboard.jsx) -- plus rien
    // ne doit y écrire.
    match /team_members/{memberId} {
      allow read, write: if false;
    }
  }
}
