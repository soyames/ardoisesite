# Copy to .env.local for local dev (Vite auto-loads .env.local, gitignored by default).
#
# Points this build at one school's backend instance -- see the ardoise
# backend repo's PROJECT_BRIEF.md ("Hosting model"): each school runs
# its own Django+DB, this frontend is one shared static app per school
# build (or per-deployment env var override at hosting time).
VITE_API_BASE_URL=http://localhost:8000
